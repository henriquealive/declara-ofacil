---
// src/components/DeclaracaoCard.astro
import type { TipoDeclaracao } from '../lib/declaracoes';

interface Props {
  declaracao: TipoDeclaracao;
}

const { declaracao } = Astro.props;
---

<a href={`/${declaracao.slug}`} class="declaracao-card">
  <div class="card-icon-wrap">
    {declaracao.icone === 'home' && (
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
        <polyline points="9,22 9,12 15,12 15,22"/>
      </svg>
    )}
    {declaracao.icone === 'wallet' && (
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="5" width="20" height="14" rx="2"/>
        <path d="M2 10h20"/>
        <circle cx="17" cy="15" r="1" fill="currentColor"/>
      </svg>
    )}
    {declaracao.icone === 'calendar' && (
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8"  y1="2" x2="8"  y2="6"/>
        <line x1="3"  y1="10" x2="21" y2="10"/>
        <polyline points="9,16 11,18 15,14"/>
      </svg>
    )}
    {declaracao.icone === 'scale' && (
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="12" y1="3" x2="12" y2="21"/>
        <path d="M17 21H7"/>
        <path d="M3 6l9-3 9 3"/>
        <path d="M3 6l3 9a3 3 0 006 0L6 6"/>
        <path d="M21 6l-3 9a3 3 0 01-6 0l6-9"/>
      </svg>
    )}
    {declaracao.icone === 'heart' && (
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
      </svg>
    )}
  </div>

  <div>
    <div class="card-title">{declaracao.titulo}</div>
    <p class="card-desc">{declaracao.descricao}</p>
  </div>

  <div class="card-cta">
    Gerar declaração
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </div>
</a>
